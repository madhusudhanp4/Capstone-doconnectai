@startuml
left to right direction

actor User
actor Admin

rectangle "DoconnectAI System" {

  usecase "Register" as UC1
  usecase "Login" as UC2
  usecase "Ask Question" as UC3
  usecase "View Questions" as UC4
  usecase "Post Answer" as UC5
  usecase "Comment on Answer" as UC6
  usecase "Upvote/Downvote Answer" as UC7
  usecase "Join Chat Room" as UC8
  usecase "Send Chat Message" as UC9
  usecase "Get AI Response" as UC10
  usecase "Accept Answer" as UC11

  usecase "Manage Users" as UC12
  usecase "Delete Inappropriate Content" as UC13
}

User --> UC1
User --> UC2
User --> UC3
User --> UC4
User --> UC5
User --> UC6
User --> UC7
User --> UC8
User --> UC9
User --> UC10
User --> UC11

Admin --> UC12
Admin --> UC13

